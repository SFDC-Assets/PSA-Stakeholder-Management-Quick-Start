                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>richTextValue</name>
                    <value>&lt;h1&gt;&lt;strong style=&quot;font-size: 28px;&quot;&gt;Stakeholder Management Quick Start&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;This page contains the necessary steps to set up salesforce to manage the people and groups your nonprofits works with.&lt;/p&gt;</value>
