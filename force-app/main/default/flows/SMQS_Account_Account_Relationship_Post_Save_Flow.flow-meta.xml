<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <assignments>
        <name>Assign_Inverse_Record</name>
        <label>Assign Inverse Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>rv_InverseAccountAccountRelationship.AccountId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.RelatedAccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rv_InverseAccountAccountRelationship.RelatedAccountId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.AccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rv_InverseAccountAccountRelationship.RelatedInverseRecordId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rv_InverseAccountAccountRelationship.IsActive</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.IsActive</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rv_InverseAccountAccountRelationship.HierarchyType</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>f_InverseRecord_HierarchyType</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rv_InverseAccountAccountRelationship.PartyRoleRelationId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>f_InverseRecords_PartyRoleRelation</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_Inverse_Record</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Checks whether the inverse AccountAccountRelation already exists. Result is used later to either create or skip inverse creation.</description>
        <name>Inverse_Record_Blank</name>
        <label>Inverse Record Blank</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>InverseRecordBlank_Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RelatedInverseRecordId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Inverse_Record</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>Creates and links inverse AccountAccountRelation (organizational affiliation) records after initial save. Linked record ids are used later for sync and delete safety.</description>
    <environments>Default</environments>
    <formulas>
        <description>This formula checks to see if the Party Role Relationship has an inverse role, or is singular and pulls the appropriate value for the Hierarchy Type.</description>
        <name>f_InverseRecord_HierarchyType</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.RelatedInverseRecordId}),
text({!$Record.PartyRoleRelation.Default_Hierarchy_Type__c}),
text({!$Record.PartyRoleRelation.RelatedInverseRecord.Default_Hierarchy_Type__c})
)</expression>
    </formulas>
    <formulas>
        <description>This formula checks to see if the Party Role Relationship has an inverse role, or is singular.</description>
        <name>f_InverseRecords_PartyRoleRelation</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.PartyRoleRelation.RelatedInverseRecordId}),
{!$Record.PartyRoleRelationId},
{!$Record.PartyRoleRelation.RelatedInverseRecordId}
)</expression>
    </formulas>
    <interviewLabel>SMQS Account Account Relationship - Post Save Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SMQS Account Account Relationship - Post Save Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Creates the inverse AccountAccountRelation record. Created id is used later to update the original record.</description>
        <name>Create_Inverse_Record</name>
        <label>Create Inverse Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Original_Record</targetReference>
        </connector>
        <inputReference>rv_InverseAccountAccountRelationship</inputReference>
    </recordCreates>
    <recordUpdates>
        <name>Update_Original_Record</name>
        <label>Update Original  Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>RelatedInverseRecordId</field>
            <value>
                <elementReference>rv_InverseAccountAccountRelationship.Id</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Inverse_Record_Blank</targetReference>
        </connector>
        <object>AccountAccountRelation</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>rv_InverseAccountAccountRelationship</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>AccountAccountRelation</objectType>
    </variables>
</Flow>
