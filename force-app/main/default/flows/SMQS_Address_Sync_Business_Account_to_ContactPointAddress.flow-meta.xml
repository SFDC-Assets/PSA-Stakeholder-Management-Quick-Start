        </inputAssignments>
        <inputAssignments>
            <name>var_AddressType</name>
            <value>
                <stringValue>Billing</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>var_EffectiveAccountName</name>
            <value>
                <elementReference>$Record.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>var_IsPersonAccount</name>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
    </subflows>
    <variables>
        <description>Collection of sparse Person Account SObjects built during Loop_Cascade_To_Members. Each element has Id and PersonMailing fields set. Updated in a single bulk DML after the loop exits in Update_Member_Person_Account.</description>
        <name>rcv_MembersToUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Account</objectType>
    </variables>
    <variables>
        <description>Sparse Person Account SObject reused each loop iteration in Assign_Update_Member to build the update payload before adding it to rcv_MembersToUpdate.</description>
        <name>var_MemberToUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Account</objectType>
    </variables>
</Flow>
