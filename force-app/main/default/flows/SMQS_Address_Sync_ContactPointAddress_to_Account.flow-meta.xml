    <description>ContactPointAddress AfterSave flow. Two paths: (1) Invalidate-and-clear — when IsUndeliverable becomes true on a CPA that was primary, clears the parent Account&apos;s main address fields (PersonMailing* or Billing* depending on IsPersonAccount). (2) Promote-to-primary — when IsPrimary becomes true and the CPA address differs from the Account&apos;s current address, updates the Account address to match. Both paths are gated by idempotent comparison guards to prevent recursion. Runs after a ContactPointAddress record is created or updated, then starts address sync back to Account.</description>
    <environments>Default</environments>
    <interviewLabel>SMQS Address Sync ContactPointAddress to Account {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SMQS Address Sync ContactPointAddress to Account</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Loads the Account to determine IsPersonAccount and current address field values for the recursion checks in Already_PersonMailing_Matches and Already_Billing_Matches.</description>
        <name>Get_Account</name>
        <label>Get Account</label>
        <locationX>842</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Action_Type</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.ParentId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Single Account update to apply the cleared or promoted address values. Uses the sparse var_AccountToUpdate SObject populated by one of the four Assign_ elements. Flow A or Flow B fires on this Account update and reconciles CPAs idempotently.</description>
        <name>Update_Parent_Account</name>
        <label>Update Parent Account</label>
        <locationX>842</locationX>
        <locationY>923</locationY>
        <inputReference>var_AccountToUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>716</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Account</targetReference>
        </connector>
        <filterFormula>ISNEW() || ISCHANGED({!$Record.IsPrimary}) || ISCHANGED({!$Record.IsUndeliverable})</filterFormula>
        <object>ContactPointAddress</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <description>Sparse Account SObject for the single parent Account update. Id and address field assignments are built by the appropriate Assign_ element before Update_Parent_Account fires.</description>
        <name>var_AccountToUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Account</objectType>
    </variables>
</Flow>
