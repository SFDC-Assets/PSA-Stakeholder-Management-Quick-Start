    <assignments>
        <description>Captures the runtime fault message when a DML operation fails, ending the flow gracefully rather than rolling back the triggering transaction.</description>
        <name>Assign_Fault_Message</name>
        <label>Capture Fault and End</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
