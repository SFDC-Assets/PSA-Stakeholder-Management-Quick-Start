            <targetReference>Add_to_Counters</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Decision_After_Screen</name>
        <label>Decision After Screen</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Count_Selected_Roles</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Create Roles</defaultConnectorLabel>
        <rules>
            <name>Is_Review_Mode</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>var_ViewMode</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ViewModeRadio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>review</stringValue>
                </rightValue>
            </conditions>
            <label>Is Review Mode</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_Is_Role_Already_Created</name>
        <label>Is Role Already Created</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Add_Suggested_Role_to_Filtered</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Created Yet</defaultConnectorLabel>
        <rules>
            <name>Already_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ExistingRoleNames</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>Loop_Filter_Suggested_Roles.Role_Name__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Filter_Suggested_Roles</targetReference>
            </connector>
            <label>Already Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_Set_View_Mode</name>
        <label>Decision Set View Mode</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Select_Relationships_and_Group_Affiliations</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Both Available</defaultConnectorLabel>
        <rules>
            <name>No_Roles_At_All</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_FilteredSuggestedRoles</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Existing_Party_Role_Relationships</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ViewMode_None</targetReference>
            </connector>
            <label>No Roles At All</label>
        </rules>
        <rules>
            <name>Create_Only</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Existing_Party_Role_Relationships</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ViewMode_Create</targetReference>
            </connector>
            <label>Create Only</label>
        </rules>
        <rules>
            <name>Review_Only</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_FilteredSuggestedRoles</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ViewMode_Review</targetReference>
            </connector>
            <label>Review Only</label>
        </rules>
    </decisions>
    <description>Provides a selection of possible party role relationship options for an end user to select and then create in the system.</description>
    <environments>Default</environments>
    <formulas>
        <name>f_now</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
    <formulas>
        <name>f_NumberOfRolesWithOutInverse</name>
        <dataType>Number</dataType>
        <expression>{!var_NumberOfRolesCreated}-({!var_NumberOfRolesWithInverse}*2)</expression>
        <scale>0</scale>
    </formulas>
