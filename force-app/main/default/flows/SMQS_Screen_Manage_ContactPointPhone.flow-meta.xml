<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <apiVersion>66.0</apiVersion>
    <assignments>
        <description>Stamps the shared IsPrimary and Invalid Reason values from Screen_Edit_Multi onto the current loop record (Loop_Apply_Multi), then adds it to var_PhonesToUpdate. Runs once per selected record. After all iterations, Update_Phones performs the DML save.</description>
        <name>Assign_Apply_Multi</name>
        <label>Stamp Values on Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>Loop_Apply_Multi.IsPrimary</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_Multi_IsPrimary</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Loop_Apply_Multi.Invalid_Reason__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_Multi_Invalid_Reason</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_PhonesToUpdate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Apply_Multi</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Apply_Multi</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Stamps the edited field values from Screen_Edit_Single onto var_SinglePhone, adds it to the var_PhonesToUpdate collection, then proceeds to Update_Phones for the DML save.</description>
        <name>Assign_Apply_Single</name>
        <label>Apply Single Record Changes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_SinglePhone.TelephoneNumber</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_TelephoneNumber</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_SinglePhone.ExtensionNumber</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_ExtensionNumber</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_SinglePhone.IsPrimary</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_IsPrimary</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_SinglePhone.UsageType</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_UsageType</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_SinglePhone.Invalid_Reason__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>field_Invalid_Reason</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_PhonesToUpdate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_SinglePhone</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Phones</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Captures the single selected record into var_SinglePhone so Screen_Edit_Single can pre-populate all fields. Loop_Capture_Single iterates var_SelectedPhones once; this assignment fires on that one iteration and stores the record, then routes to Screen_Edit_Single.</description>
        <name>Assign_Capture_Single</name>
        <label>Capture Single Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_SinglePhone</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Capture_Single</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Screen_Edit_Single</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Counts the records the user selected in the data table and stores the result in var_Count. var_Count is evaluated by Decision_Route_by_Count to route to the single-record or multi-record edit screen.</description>
        <name>Count_Selected_Phones</name>
        <label>Count Selected Phones</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_Count</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>var_SelectedPhones</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Decision_Route_by_Count</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Routes based on var_Count. If exactly 1 record was selected, routes to Loop_Capture_Single which populates var_SinglePhone before showing Screen_Edit_Single with all fields pre-populated. If more than 1, routes to Screen_Edit_Multi where only IsPrimary and Invalid Reason are editable and applied uniformly to all selected records.</description>
        <name>Decision_Route_by_Count</name>
        <label>Single or Multiple Records?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Screen_Edit_Multi</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Multiple Records</defaultConnectorLabel>
        <rules>
            <name>Is_Single</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_Count</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Capture_Single</targetReference>
            </connector>
            <label>Single Record</label>
        </rules>
    </decisions>
    <description>Screen flow on the Account record page to manage ContactPointPhone records. Select one or more records to edit. Sync flows handle downstream Account field updates.</description>
    <dynamicChoiceSets>
        <name>dcs_Invalid_Reason</name>
        <dataType>Picklist</dataType>
        <displayField xsi:nil="true"/>
        <object xsi:nil="true"/>
        <picklistField>Invalid_Reason__c</picklistField>
        <picklistObject>ContactPointPhone</picklistObject>
    </dynamicChoiceSets>
    <dynamicChoiceSets>
        <name>dcs_UsageType</name>
        <dataType>Picklist</dataType>
        <displayField xsi:nil="true"/>
        <object xsi:nil="true"/>
        <picklistField>UsageType</picklistField>
        <picklistObject>ContactPointPhone</picklistObject>
    </dynamicChoiceSets>
    <environments>Default</environments>
    <interviewLabel>SMQS Manage ContactPointPhone {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SMQS Screen Manage ContactPointPhone</label>
    <loops>
        <description>Iterates over each record in var_SelectedPhones. For each iteration, Assign_Apply_Multi stamps the shared IsPrimary and Invalid Reason values from Screen_Edit_Multi and adds the record to var_PhonesToUpdate. After all iterations, Update_Phones performs the DML save.</description>
        <name>Loop_Apply_Multi</name>
        <label>Apply to Each Selected Phone</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>var_SelectedPhones</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Apply_Multi</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Update_Phones</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <description>Iterates var_SelectedPhones exactly once (only reached when var_Count = 1). The single iteration fires Assign_Capture_Single to store the record in var_SinglePhone, which then routes to Screen_Edit_Single with all fields pre-populated.</description>
        <name>Loop_Capture_Single</name>
        <label>Capture Single Selected Phone</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>var_SelectedPhones</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Capture_Single</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Screen_Edit_Single</targetReference>
        </noMoreValuesConnector>
    </loops>
