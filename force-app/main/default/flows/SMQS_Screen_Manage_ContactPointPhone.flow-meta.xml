        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordLookups>
        <description>Retrieves all ContactPointPhone records for this Account (filtered by ParentId = recordId). Results are stored in var_AllPhones and bound to the data table on Screen_Select so the user can select records to edit.</description>
        <name>Get_Phone_Records</name>
        <label>Get Phone Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Screen_Select</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ParentId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <object>ContactPointPhone</object>
        <outputReference>var_AllPhones</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>TelephoneNumber</queriedFields>
        <queriedFields>ExtensionNumber</queriedFields>
        <queriedFields>IsPrimary</queriedFields>
        <queriedFields>UsageType</queriedFields>
        <queriedFields>Invalid_Reason__c</queriedFields>
    </recordLookups>
    <recordUpdates>
        <description>Performs a single DML update on all records in var_PhonesToUpdate (either one record from the single path or multiple from the multi path). On success, routes to Screen_Success. On fault, routes to Screen_Error where the system fault message is displayed.</description>
        <name>Update_Phones</name>
        <label>Update Phone Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Screen_Success</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Screen_Error</targetReference>
        </faultConnector>
        <inputReference>var_PhonesToUpdate</inputReference>
    </recordUpdates>
