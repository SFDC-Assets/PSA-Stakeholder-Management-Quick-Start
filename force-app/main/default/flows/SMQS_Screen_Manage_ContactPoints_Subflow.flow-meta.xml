    <assignments>
        <name>Assign_Household_AccountId</name>
        <label>Set ACR AccountId to Household</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ACR_AccountId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Household_AccountId_From_Person.AccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>out_PersonACR</assignToReference>
            <operator>Assign</operator>
