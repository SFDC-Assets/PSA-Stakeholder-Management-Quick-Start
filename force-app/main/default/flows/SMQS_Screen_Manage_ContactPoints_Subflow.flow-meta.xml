    <assignments>
        <description>Household/Business path. Sets var_ACR_AccountId to recordId so the 4 shared ACR queries filter by the account the flow was launched from.</description>
        <name>Assign_RecordId_As_AccountId</name>
        <label>Set ACR AccountId to RecordId</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ACR_AccountId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>out_HouseholdName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>out_Account.Name</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_ACRs_Sync_Yes</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Routes Person Accounts to look up the household AccountId first. Routes Household/Business accounts to set var_ACR_AccountId = recordId directly.</description>
        <name>Decision_ACR_Query_Path</name>
        <label>Person Account or Household?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_RecordId_As_AccountId</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Household / Business</defaultConnectorLabel>
        <rules>
            <name>Is_Person_Account</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>out_Account.IsPersonAccount</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Household_AccountId_From_Person</targetReference>
            </connector>
            <label>Person Account</label>
        </rules>
    </decisions>
    <description>Autolaunched subflow called by SMQS_Screen_Manage_ContactPoints at the start of every session. Outputs ACR counts for all four sync groups. Queries the Account, then routes ACR queries by account type: Person Accounts query ACRs by ContactId = PersonContactId; Household and Business accounts query ACRs by AccountId = recordId. Both paths query ContactPointAddress, Email, and Phone records and return all results as output variables to the parent.</description>
    <environments>Default</environments>
    <interviewLabel>SMQS Manage ContactPoints Subflow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SMQS Screen Manage ContactPoints Subflow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Retrieves the Account record for recordId, querying Id, Name, and IsPersonAccount. IsPersonAccount is returned to the parent to drive Decision_Account_Type. Fault propagates to parent.</description>
        <name>Get_Account</name>
        <label>Get Account</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_ACR_Query_Path</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <object>Account</object>
        <outputReference>out_Account</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>IsPersonAccount</queriedFields>
        <queriedFields>Is_Household__c</queriedFields>
        <queriedFields>PersonContactId</queriedFields>
        <queriedFields>PersonDoNotCall</queriedFields>
        <queriedFields>Do_Not_Mail__c</queriedFields>
        <queriedFields>PersonHasOptedOutOfEmail</queriedFields>
    </recordLookups>
    <recordLookups>
        <description>Retrieves active AccountContactRelation records for this Account where Sync_Household_Address__c = false. Output stored in out_NoSyncACRs. Fault propagates to parent.</description>
        <name>Get_ACRs_Sync_No</name>
        <label>Get ACRs — Address Sync Off</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_ACRs_Sync_Phone_Yes</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>AccountId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_ACR_AccountId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Sync_Household_Address__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>AccountContactRelation</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
