<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <fields>
        <fullName>Default_Hierarchy_Type__c</fullName>
        <description>This field is used to populate the Hierarchy Type field when connecting individuals to other individuals or groups. It is used to place that relationship above, at the same level, or below others in the Actionable Relationship Center.</description>
        <inlineHelpText>This field describes the relationship between the Role and the Related Role, as one that is higher (Parent), equal (Peer), or lower (Child).</inlineHelpText>
        <label>Default Hierarchy Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Parent</fullName>
                    <default>true</default>
                    <label>Parent</label>
                </value>
                <value>
                    <fullName>Child</fullName>
                    <default>false</default>
                    <label>Child</label>
                </value>
                <value>
                    <fullName>Peer</fullName>
                    <default>false</default>
                    <label>Peer</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>External_Id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <externalId>true</externalId>
        <label>External Id</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <label>Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Immediate Family</fullName>
                    <default>false</default>
                    <label>Immediate Family</label>
                </value>
                <value>
                    <fullName>Extended Family</fullName>
                    <default>false</default>
                    <label>Extended Family</label>
                </value>
                <value>
                    <fullName>Nonprofit</fullName>
                    <default>false</default>
                    <label>Nonprofit</label>
                </value>
                <value>
                    <fullName>Business</fullName>
                    <default>false</default>
                    <label>Business</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <listViews>
        <fullName>Group_Affiliations_AAR</fullName>
        <columns>Name</columns>
        <columns>RelatedInverseRecord</columns>
        <columns>RelatedRoleName</columns>
        <columns>RelationshipObjectName</columns>
        <columns>ShouldCreaInversRoleAuto</columns>
        <columns>RoleName</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RelationshipObjectName</field>
            <operation>equals</operation>
            <value>0</value>
        </filters>
        <label>Group Affiliations (AAR)</label>
    </listViews>
    <listViews>
        <fullName>Individual_Relationships_CCR</fullName>
        <columns>Name</columns>
        <columns>RelatedInverseRecord</columns>
        <columns>RelatedRoleName</columns>
        <columns>RelationshipObjectName</columns>
        <columns>ShouldCreaInversRoleAuto</columns>
        <columns>RoleName</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RelationshipObjectName</field>
            <operation>equals</operation>
            <value>1</value>
        </filters>
        <label>Individual Relationships (CCR)</label>
    </listViews>
</CustomObject>
